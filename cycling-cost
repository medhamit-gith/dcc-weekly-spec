<script>
// ── TAB SWITCHING ────────────────────────────────────
function switchTab(id, btn) {
  document.querySelectorAll('.tab-panel').forEach(p => p.classList.remove('active'));
  document.querySelectorAll('.tab-btn').forEach(b => b.classList.remove('active'));
  document.getElementById('tab-' + id).classList.add('active');
  btn.classList.add('active');
  // Re-trigger animations
  animateBars();
  animateVBars();
  animateDonut();
}

// ── DATA ─────────────────────────────────────────────
const yearData = [
  { year:'2020', amount:2500,    color:'#007AFF' },
  { year:'2022', amount:520,     color:'#FF2D55' },
  { year:'2023', amount:2978,    color:'#FF9500' },
  { year:'2024', amount:0,       color:'#34C759' },
  { year:'2025', amount:5928.91, color:'#5856D6' },
  { year:'2026', amount:401.97,  color:'#5AC8FA' },
];

const allItems = [
  { label:'Cervélo Caledonia-5', sub:'Strype St · Apr 2025 · #23838279',  amount:5000,   color:'#5856D6', emoji:'🏆' },
  { label:'Orro Gold Disc',       sub:'Elite Cycling · Aug 2020 · #2668',  amount:2500,   color:'#007AFF', emoji:'🚲' },
  { label:'Rapha Clothing',       sub:'8 orders · Net after £577 returns', amount:1498,   color:'#FF2D55', emoji:'👕' },
  { label:'Café du Cycliste',     sub:'3 orders · Sep–Dec 2023',           amount:1020,   color:'#FF9500', emoji:'☕' },
  { label:'Garmin Edge 1040 + Varia', sub:'May 2023 · #104241504175',      amount:979.98, color:'#34C759', emoji:'📡' },
  { label:'Platinum Service',     sub:'Giant St Pauls · Nov 2025',         amount:508.91, color:'#5856D6', emoji:'⚙️' },
  { label:'Insta360 GO Ultra',    sub:'Costco · Dec 2025',                 amount:299.99, color:'#5AC8FA', emoji:'📷' },
  { label:'Jig Bike Fit (SSC)',   sub:'Cervélo fit · Mar 2025',            amount:240,    color:'#5856D6', emoji:'📐' },
  { label:'SSC Workshop',         sub:'Seatpost + Labour · May 2025',      amount:180,    color:'#FF9500', emoji:'🔩' },
  { label:'Memberships',          sub:'BC Premium + Rapha RCC',            amount:147,    color:'#FF2D55', emoji:'🎫' },
  { label:'Continental Gator ×2', sub:'Cambrian Tyres · Feb 2026',         amount:101.98, color:'#FF6B00', emoji:'🛞' },
];

const raphaOrders = [
  { label:'Pro Team Shoes + Brevet Jersey',          amount:545 },
  { label:'Rain Jacket + Bibs + Lightweight Jersey', amount:345 },
  { label:'Glasses + Socks + Cap (net)',             amount:213 },
  { label:'Overshoes + Festive Jersey',              amount:175 },
  { label:'Helmet + Merino Gloves',                  amount:145 },
  { label:'RCC Membership',                          amount:75  },
];

// ── BUILD ALL ITEMS LIST ─────────────────────────────
function buildAllItems() {
  const el = document.getElementById('all-items');
  if (!el) return;
  el.innerHTML = allItems.map(item => `
    <div class="row-item">
      <div class="row-left">
        <div class="row-ico" style="background:${item.color}18">${item.emoji}</div>
        <div>
          <div class="row-title">${item.label}</div>
          <div class="row-sub">${item.sub}</div>
        </div>
      </div>
      <div class="row-right">
        <div class="row-amt" style="color:${item.color}">£${item.amount.toLocaleString('en-GB',{minimumFractionDigits:2,maximumFractionDigits:2})}</div>
      </div>
    </div>`).join('');
}

// ── BUILD YEAR BARS (horizontal) ────────────────────
function buildYearBars() {
  const el = document.getElementById('year-bars');
  if (!el) return;
  const max = Math.max(...yearData.map(d => d.amount));
  const labels = { '2020':'Orro Gold Disc', '2022':'Rapha clothing', '2023':'Rapha + Garmin + CdC', '2024':'Bike Fit (free)', '2025':'Cervélo + Fit + Services', '2026':'Insta360 + Tyres' };
  el.innerHTML = yearData.map(d => `
    <div class="bar-row">
      <div class="bar-meta">
        <span class="bar-name">${d.year} <span style="color:var(--label3);font-weight:400">${labels[d.year]}</span></span>
        <span class="bar-amt" style="color:${d.color}">${d.amount > 0 ? '£' + d.amount.toLocaleString('en-GB',{minimumFractionDigits:0,maximumFractionDigits:0}) : '—'}</span>
      </div>
      <div class="bar-track"><div class="bar-fill" data-pct="${(d.amount/max*100).toFixed(1)}" style="background:${d.color}"></div></div>
    </div>`).join('');
}

// ── BUILD VERTICAL BAR CHART ─────────────────────────
function buildVBars() {
  const el = document.getElementById('vbar-container');
  if (!el) return;
  const max = Math.max(...yearData.map(d => d.amount));
  el.innerHTML = yearData.map(d => `
    <div class="vbar-col">
      <div style="flex:1;display:flex;align-items:flex-end;width:100%">
        <div class="vbar-bar" data-pct="${d.amount/max*100}" style="background:linear-gradient(180deg,${d.color} 0%,${d.color}88 100%)"></div>
      </div>
      <div class="vbar-yr">${d.year}</div>
    </div>`).join('');
}

// ── BUILD RAPHA BARS ─────────────────────────────────
function buildRaphaBars() {
  const el = document.getElementById('rapha-bars');
  if (!el) return;
  const max = Math.max(...raphaOrders.map(d => d.amount));
  el.innerHTML = raphaOrders.map((o,i) => `
    <div class="bar-row">
      <div class="bar-meta">
        <span class="bar-name">${o.label}</span>
        <span class="bar-amt" style="color:#FF2D55">${o.amount > 0 ? '£'+o.amount : 'FREE'}</span>
      </div>
      <div class="bar-track"><div class="bar-fill" data-pct="${(o.amount/max*100).toFixed(1)}" style="background:linear-gradient(90deg,#FF2D55,#FF6B81)"></div></div>
    </div>`).join('');
}

// ── ANIMATE BARS ──────────────────────────────────────
function animateBars() {
  setTimeout(() => {
    document.querySelectorAll('.bar-fill').forEach((bar, i) => {
      const pct = bar.dataset.pct || 0;
      bar.style.width = '0';
      setTimeout(() => { bar.style.width = pct + '%'; }, i * 60);
    });
  }, 100);
}

// ── ANIMATE VERTICAL BARS ────────────────────────────
function animateVBars() {
  setTimeout(() => {
    document.querySelectorAll('.vbar-bar').forEach((bar, i) => {
      const pct = bar.dataset.pct || 0;
      bar.style.height = '0';
      setTimeout(() => { bar.style.height = pct + '%'; }, i * 80);
    });
  }, 150);
}

// ── ANIMATE DONUT ─────────────────────────────────────
function animateDonut() {
  const segs = document.querySelectorAll('.donut-seg');
  segs.forEach(seg => {
    const target = parseFloat(seg.dataset.target);
    const offset = parseFloat(seg.dataset.offset);
    const circ = 439.8; // 2 * π * 70
    seg.style.strokeDasharray = `0 ${circ}`;
    seg.style.strokeDashoffset = -offset;
    seg.style.transition = 'none';
    setTimeout(() => {
      seg.style.transition = 'stroke-dasharray 1s cubic-bezier(.34,1.2,.64,1)';
      seg.style.strokeDasharray = `${target} ${circ - target}`;
      seg.style.strokeDashoffset = offset;
    }, 200);
  });
}

// ── INIT ──────────────────────────────────────────────
document.addEventListener('DOMContentLoaded', () => {
  buildAllItems();
  buildYearBars();
  buildVBars();
  buildRaphaBars();
  setTimeout(() => {
    animateBars();
    animateVBars();
    animateDonut();
  }, 300);
});
</script>
