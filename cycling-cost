<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Cycling Investment Dashboard — Amit Kamat</title>
<style>
/* ── RESET & BASE ── */
*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

:root {
  --blue:    #007AFF;
  --indigo:  #5856D6;
  --purple:  #AF52DE;
  --pink:    #FF2D55;
  --orange:  #FF9500;
  --yellow:  #FFCC00;
  --green:   #34C759;
  --teal:    #5AC8FA;
  --red:     #FF3B30;
  --bg:      #F2F2F7;
  --card:    #FFFFFF;
  --label1:  #000000;
  --label2:  #1C1C1E;
  --label3:  rgba(60,60,67,0.6);
  --label4:  rgba(60,60,67,0.3);
  --sep:     rgba(60,60,67,0.12);
}

body {
  font-family: -apple-system, 'SF Pro Display', 'SF Pro Text', BlinkMacSystemFont, 'Helvetica Neue', Arial, sans-serif;
  background: var(--bg);
  color: var(--label1);
  -webkit-font-smoothing: antialiased;
  -moz-osx-font-smoothing: grayscale;
  min-height: 100vh;
}

.app { max-width: 680px; margin: 0 auto; }

/* ── HEADER ── */
.hero {
  background: linear-gradient(160deg, #09090F 0%, #1A1A2E 55%, #0F0F20 100%);
  padding: 56px 22px 0;
  position: relative;
  overflow: hidden;
}
.hero-blob {
  position: absolute; border-radius: 50%; pointer-events: none;
}
.hero-blob-1 { top:-80px; right:-60px; width:280px; height:280px; background:radial-gradient(circle,rgba(0,122,255,.22) 0%,transparent 70%); }
.hero-blob-2 { top:20px;  left:-80px;  width:210px; height:210px; background:radial-gradient(circle,rgba(88,86,214,.18) 0%,transparent 70%); }
.hero-blob-3 { bottom:0;  right:40px;  width:170px; height:170px; background:radial-gradient(circle,rgba(90,200,250,.12) 0%,transparent 70%); }

.hero-content { position: relative; z-index: 1; }

.hero-eyebrow {
  font-size: 11px; font-weight: 700; letter-spacing: .1em;
  text-transform: uppercase; color: var(--blue); margin-bottom: 10px;
}
.hero-name   { font-size: 36px; font-weight: 800; color:#fff; letter-spacing:-1.2px; line-height:1.05; margin-bottom:6px; }
.hero-sub    { font-size: 14px; color:rgba(255,255,255,.42); font-weight:400; margin-bottom:22px; }

/* TOTAL GLASS CARD */
.hero-total {
  background: rgba(255,255,255,.08);
  border: 1px solid rgba(255,255,255,.11);
  border-radius: 22px;
  padding: 22px 22px 20px;
  backdrop-filter: blur(20px);
  -webkit-backdrop-filter: blur(20px);
  margin-bottom: 20px;
}
.hero-total-lbl { font-size:11px; font-weight:700; letter-spacing:.06em; text-transform:uppercase; color:rgba(255,255,255,.45); margin-bottom:6px; }
.hero-total-val { font-size:54px; font-weight:800; color:#fff; letter-spacing:-3px; line-height:1; margin-bottom:18px; }
.hero-total-val span { font-size:28px; font-weight:600; color:rgba(255,255,255,.42); }
.hero-stats { display:flex; gap:22px; flex-wrap:wrap; }
.hero-stat-val { font-size:16px; font-weight:700; color:#fff; }
.hero-stat-lbl { font-size:11px; color:rgba(255,255,255,.4); font-weight:500; margin-top:2px; }

.hero-badges { display:flex; gap:8px; flex-wrap:wrap; margin-bottom:20px; }
.hero-badge {
  background:rgba(255,255,255,.08);
  border:1px solid rgba(255,255,255,.12);
  border-radius:20px; padding:5px 12px;
  font-size:12px; color:rgba(255,255,255,.7); font-weight:500;
}

/* TAB BAR */
.tab-bar {
  display:flex;
  background:rgba(255,255,255,.07);
  border-radius:16px 16px 0 0;
  padding:6px 6px 0;
  gap:2px;
  position:relative; z-index:1;
}
.tab-btn {
  flex:1; border:none; cursor:pointer;
  padding:10px 6px;
  border-radius:12px 12px 0 0;
  background:transparent;
  color:rgba(255,255,255,.45);
  font-size:11px; font-weight:600;
  transition:all .2s ease;
  display:flex; flex-direction:column; align-items:center; gap:3px;
  font-family:inherit;
  line-height:1;
}
.tab-btn.active { background:var(--bg); color:var(--blue); }
.tab-btn .tab-icon { font-size:18px; }

/* ── CONTENT ── */
.content { padding:16px 16px 40px; }
.tab-panel { display:none; }
.tab-panel.active { display:block; }

/* ── SECTION LABEL ── */
.section-lbl {
  font-size:20px; font-weight:700; letter-spacing:-.4px;
  color:var(--label1); margin:26px 0 12px; padding-left:2px;
}

/* ── CARD ── */
.card {
  background:var(--card);
  border-radius:20px;
  padding:20px;
  box-shadow:0 2px 16px rgba(0,0,0,.07), 0 1px 3px rgba(0,0,0,.05);
  margin-bottom:14px;
}
.card-title {
  font-size:11px; font-weight:700; letter-spacing:.06em;
  text-transform:uppercase; color:var(--label3); margin-bottom:16px;
}

/* ── GRID ── */
.grid2 { display:grid; grid-template-columns:1fr 1fr; gap:12px; margin-bottom:14px; }
.grid3 { display:grid; grid-template-columns:1fr 1fr 1fr; gap:10px; margin-bottom:14px; }

/* ── QUICK STATS ── */
.stat-card { background:var(--card); border-radius:18px; padding:18px 16px; box-shadow:0 2px 14px rgba(0,0,0,.06); }
.stat-icon { font-size:26px; margin-bottom:10px; }
.stat-val  { font-size:30px; font-weight:700; letter-spacing:-.6px; color:var(--label1); }
.stat-lbl  { font-size:11px; color:var(--label3); font-weight:500; margin-top:3px; }

/* ── DONUT ── */
.donut-wrap { position:relative; width:180px; height:180px; margin:0 auto 20px; }
.donut-center {
  position:absolute; top:50%; left:50%;
  transform:translate(-50%,-50%); text-align:center;
}
.donut-center-val { font-size:20px; font-weight:700; letter-spacing:-.5px; }
.donut-center-lbl { font-size:10px; color:var(--label3); font-weight:600; letter-spacing:.05em; text-transform:uppercase; }
.donut-svg { transform:rotate(-90deg); }

/* ── LEGEND ── */
.legend { display:flex; flex-direction:column; gap:13px; }
.legend-item { display:flex; align-items:center; justify-content:space-between; }
.legend-left { display:flex; align-items:center; gap:9px; }
.legend-dot  { width:10px; height:10px; border-radius:50%; flex-shrink:0; }
.legend-name { font-size:13px; font-weight:500; color:var(--label2); }
.legend-val  { font-size:14px; font-weight:700; }
.legend-pct  { font-size:11px; color:var(--label3); margin-left:5px; }

/* ── BAR CHART ── */
.bar-list { display:flex; flex-direction:column; gap:14px; }
.bar-meta { display:flex; justify-content:space-between; margin-bottom:6px; align-items:baseline; }
.bar-name { font-size:13px; font-weight:500; color:var(--label2); }
.bar-amt  { font-size:13px; font-weight:700; }
.bar-track { height:7px; background:var(--bg); border-radius:4px; overflow:hidden; }
.bar-fill  { height:100%; border-radius:4px; width:0; transition:width 1s cubic-bezier(.34,1.2,.64,1); }

/* ── VERTICAL BAR ── */
.vbar-wrap {
  display:flex; align-items:flex-end; gap:8px;
  height:130px; margin-bottom:8px;
}
.vbar-col { flex:1; display:flex; flex-direction:column; align-items:center; height:100%; }
.vbar-col .vbar-bar { width:100%; border-radius:8px 8px 3px 3px; transition:height 1s cubic-bezier(.34,1.2,.64,1); height:0; }
.vbar-col .vbar-yr { font-size:10px; font-weight:600; color:var(--label3); margin-top:6px; }

/* ── ROW LISTS ── */
.row-list .row-item {
  display:flex; align-items:center; justify-content:space-between;
  padding:12px 0;
  border-bottom:1px solid var(--sep);
  gap:12px;
}
.row-list .row-item:last-child { border-bottom:none; }
.row-left { display:flex; align-items:center; gap:12px; flex:1; min-width:0; }
.row-ico  { width:40px; height:40px; border-radius:12px; display:flex; align-items:center; justify-content:center; font-size:18px; flex-shrink:0; }
.row-title { font-size:14px; font-weight:600; color:var(--label1); white-space:nowrap; overflow:hidden; text-overflow:ellipsis; }
.row-sub   { font-size:11px; color:var(--label3); margin-top:2px; }
.row-right { text-align:right; flex-shrink:0; }
.row-amt   { font-size:15px; font-weight:700; }
.row-tag   { display:inline-block; border-radius:6px; padding:2px 7px; font-size:10px; font-weight:700; margin-top:3px; }

/* ── TOTAL ROW ── */
.total-row {
  display:flex; justify-content:space-between; align-items:center;
  margin-top:12px; padding:15px 18px;
  background:linear-gradient(135deg,var(--blue) 0%,var(--indigo) 100%);
  border-radius:14px;
}
.total-row-lbl { font-size:13px; font-weight:700; color:rgba(255,255,255,.75); }
.total-row-val { font-size:22px; font-weight:800; color:#fff; letter-spacing:-.5px; }

/* ── BIKE CARDS ── */
.bike-card { border-radius:22px; overflow:hidden; box-shadow:0 4px 24px rgba(0,0,0,.12); margin-bottom:16px; }
.bike-header { padding:24px 22px; position:relative; overflow:hidden; }
.bike-header-bg { position:absolute; right:-20px; top:-20px; font-size:110px; opacity:.1; line-height:1; }
.bike-emoji  { font-size:32px; margin-bottom:10px; position:relative; z-index:1; }
.bike-name   { font-size:26px; font-weight:800; color:#fff; letter-spacing:-.8px; margin-bottom:2px; position:relative; z-index:1; }
.bike-year   { font-size:13px; color:rgba(255,255,255,.6); margin-bottom:14px; position:relative; z-index:1; }
.bike-price  { font-size:44px; font-weight:800; color:#fff; letter-spacing:-2px; position:relative; z-index:1; }
.bike-retailer { font-size:12px; color:rgba(255,255,255,.48); margin-top:3px; position:relative; z-index:1; }
.bike-tags   { display:flex; gap:6px; flex-wrap:wrap; margin-top:14px; position:relative; z-index:1; }
.bike-tag    { background:rgba(255,255,255,.18); color:#fff; border-radius:8px; padding:4px 10px; font-size:11px; font-weight:600; }
.bike-body   { background:#fff; }
.bike-row    { display:flex; justify-content:space-between; align-items:center; padding:13px 22px; border-bottom:1px solid var(--sep); }
.bike-row:last-child { border-bottom:none; }
.bike-row-lbl { font-size:13px; color:var(--label3); font-weight:500; }
.bike-row-val { font-size:13px; font-weight:600; color:var(--label1); max-width:58%; text-align:right; }
.bike-footer  { padding:14px 22px; border-top-width:1px; border-top-style:solid; }
.bike-footer-lbl { font-size:11px; font-weight:700; text-transform:uppercase; letter-spacing:.05em; margin-bottom:4px; }
.bike-footer-val { font-size:13px; font-weight:500; color:var(--label1); }

/* ── COMBINED BANNER ── */
.combined-banner {
  background:linear-gradient(135deg,var(--blue) 0%,var(--indigo) 100%);
  border-radius:20px; text-align:center; padding:26px 20px;
  margin-bottom:16px; box-shadow:0 4px 20px rgba(0,122,255,.3);
}
.combined-lbl { font-size:12px; font-weight:600; color:rgba(255,255,255,.55); letter-spacing:.06em; text-transform:uppercase; margin-bottom:4px; }
.combined-val { font-size:48px; font-weight:800; color:#fff; letter-spacing:-2px; }
.combined-sub { font-size:13px; color:rgba(255,255,255,.5); margin-top:4px; }

/* ── SERVICE CHIPS ── */
.svc-chips { display:flex; flex-wrap:wrap; gap:10px; margin-bottom:16px; }
.svc-chip { background:var(--bg); border-radius:14px; padding:13px 16px; min-width:120px; }
.svc-chip-val { font-size:20px; font-weight:700; margin-bottom:4px; }
.svc-chip-lbl { font-size:11px; color:var(--label3); line-height:1.4; }

/* ── BRAND COMPARE ── */
.brand-col { border-radius:20px; overflow:hidden; box-shadow:0 4px 18px rgba(0,0,0,.09); }
.brand-header { padding:18px 16px; }
.brand-header-ico  { font-size:28px; margin-bottom:6px; }
.brand-header-name { font-size:17px; font-weight:800; color:#fff; letter-spacing:-.3px; }
.brand-header-val  { font-size:30px; font-weight:800; color:#fff; letter-spacing:-1.2px; margin-top:6px; }
.brand-header-sub  { font-size:11px; color:rgba(255,255,255,.5); margin-top:3px; }
.brand-body { background:#fff; padding:12px 16px; }
.brand-body-row { display:flex; justify-content:space-between; font-size:12px; padding:4px 0; }
.brand-body-lbl { color:var(--label3); }
.brand-body-val { font-weight:600; }

/* ── ORDER ROWS ── */
.order-summary {
  display:flex; justify-content:space-between; align-items:center;
  margin-top:12px; padding:13px 16px;
  border-radius:13px;
}
.order-summary-group { text-align:center; }
.order-summary-lbl { font-size:11px; color:var(--label3); margin-bottom:3px; }
.order-summary-val { font-size:17px; font-weight:700; }

/* ── TIMELINE ── */
.tl-item { display:flex; gap:14px; padding-bottom:20px; position:relative; }
.tl-item:last-child { padding-bottom:0; }
.tl-connector {
  position:absolute; left:21px; top:44px; bottom:0; width:2px;
  background:var(--sep);
}
.tl-ico { width:44px; height:44px; border-radius:14px; display:flex; align-items:center; justify-content:center; font-size:20px; flex-shrink:0; z-index:1; }
.tl-body { flex:1; }
.tl-date  { font-size:11px; color:var(--label3); margin-bottom:2px; }
.tl-title { font-size:14px; font-weight:700; color:var(--label1); }
.tl-sub   { font-size:12px; color:var(--label3); margin-top:3px; line-height:1.4; }
.tl-right { text-align:right; flex-shrink:0; }
.tl-amt   { font-size:16px; font-weight:800; letter-spacing:-.3px; }
.tl-tag   { display:inline-block; border-radius:6px; padding:2px 8px; font-size:10px; font-weight:700; margin-top:4px; }

/* ── FACT CARDS ── */
.fact-card { background:var(--card); border-radius:18px; padding:20px 14px; text-align:center; box-shadow:0 2px 14px rgba(0,0,0,.06); }
.fact-icon { font-size:24px; margin-bottom:10px; }
.fact-val  { font-size:28px; font-weight:800; letter-spacing:-.8px; }
.fact-name { font-size:12px; font-weight:700; color:var(--label1); margin:5px 0 3px; }
.fact-desc { font-size:11px; color:var(--label3); line-height:1.5; }

/* ── EVIDENCE ── */
.ev-item { display:flex; justify-content:space-between; align-items:center; padding:12px 0; border-bottom:1px solid var(--sep); }
.ev-item:last-child { border-bottom:none; }
.ev-lbl { font-size:14px; font-weight:500; color:var(--label1); }
.ev-chip { border-radius:8px; padding:4px 10px; font-size:12px; font-weight:600; }

/* ── ANIMATIONS ── */
@keyframes fadeUp {
  from { opacity:0; transform:translateY(14px); }
  to   { opacity:1; transform:translateY(0); }
}
.card, .stat-card, .bike-card, .combined-banner, .brand-col, .fact-card {
  animation: fadeUp .45s ease both;
}

/* ── RESPONSIVE ── */
@media(max-width:480px) {
  .grid3 { grid-template-columns:1fr 1fr; }
  .hero-total-val { font-size:42px; }
  .bike-price { font-size:36px; }
}
@media(max-width:360px) {
  .grid3 { grid-template-columns:1fr 1fr; }
  .grid2 { grid-template-columns:1fr; }
}
</style>
</head>
<body>
<div class="app">

<!-- ══════════════ HERO ══════════════ -->
<div class="hero">
  <div class="hero-blob hero-blob-1"></div>
  <div class="hero-blob hero-blob-2"></div>
  <div class="hero-blob hero-blob-3"></div>
  <div class="hero-content">
    <div class="hero-eyebrow">Cycling Investment Portfolio</div>
    <div class="hero-name">Amit Kamat</div>
    <div class="hero-sub">2020 – 2026 · All Email & Invoice-Verified Purchases</div>

    <div class="hero-total">
      <div class="hero-total-lbl">Total Confirmed Investment</div>
      <div class="hero-total-val">£12,400<span>.86</span></div>
      <div class="hero-stats">
        <div><div class="hero-stat-val">£7,500</div><div class="hero-stat-lbl">Bikes · 60.5%</div></div>
        <div><div class="hero-stat-val">£2,518</div><div class="hero-stat-lbl">Clothing · 20.3%</div></div>
        <div><div class="hero-stat-val">£1,129</div><div class="hero-stat-lbl">Services · 9.1%</div></div>
        <div><div class="hero-stat-val">£980</div><div class="hero-stat-lbl">Electronics · 7.9%</div></div>
      </div>
    </div>

    <div class="hero-badges">
      <div class="hero-badge">✅ 100% Verified</div>
      <div class="hero-badge">📄 March 2026</div>
      <div class="hero-badge">🚲 2 Bikes</div>
      <div class="hero-badge">6 Years</div>
    </div>
  </div>

  <!-- TAB BAR -->
  <div class="tab-bar">
    <button class="tab-btn active" onclick="switchTab('overview',this)">
      <span class="tab-icon">⬡</span><span>Overview</span>
    </button>
    <button class="tab-btn" onclick="switchTab('bikes',this)">
      <span class="tab-icon">🚲</span><span>Bikes</span>
    </button>
    <button class="tab-btn" onclick="switchTab('clothing',this)">
      <span class="tab-icon">👕</span><span>Clothing</span>
    </button>
    <button class="tab-btn" onclick="switchTab('timeline',this)">
      <span class="tab-icon">📅</span><span>Timeline</span>
    </button>
  </div>
</div>

<!-- ══════════════ CONTENT ══════════════ -->
<div class="content">

  <!-- ════ OVERVIEW ════ -->
  <div id="tab-overview" class="tab-panel active">

    <!-- Quick Stats -->
    <div class="grid3">
      <div class="stat-card" style="animation-delay:.05s">
        <div class="stat-icon">🏆</div>
        <div class="stat-val">2</div>
        <div class="stat-lbl">Premium Bikes</div>
      </div>
      <div class="stat-card" style="animation-delay:.1s">
        <div class="stat-icon">🛍️</div>
        <div class="stat-val">14</div>
        <div class="stat-lbl">Total Orders</div>
      </div>
      <div class="stat-card" style="animation-delay:.15s">
        <div class="stat-icon">🔧</div>
        <div class="stat-val">4</div>
        <div class="stat-lbl">Pro Services</div>
      </div>
    </div>

    <!-- Spend Breakdown + Donut -->
    <div class="section-lbl">Spend Breakdown</div>
    <div class="card" style="animation-delay:.2s">
      <div class="card-title">By Category</div>
      <div class="donut-wrap">
        <svg class="donut-svg" viewBox="0 0 180 180" width="180" height="180">
          <!-- background ring -->
          <circle cx="90" cy="90" r="70" fill="none" stroke="rgba(120,120,128,.1)" stroke-width="22"/>
          <!-- Bikes 60.5% → dasharray = pct/100 * 2πr = .605 * 439.8 = 266.1 -->
          <circle cx="90" cy="90" r="70" fill="none" stroke="#007AFF" stroke-width="22"
            stroke-dasharray="266.1 173.7" stroke-dashoffset="0" stroke-linecap="butt"
            class="donut-seg" data-target="266.1" data-offset="0"/>
          <!-- Clothing 20.3% → 89.3 -->
          <circle cx="90" cy="90" r="70" fill="none" stroke="#FF9500" stroke-width="22"
            stroke-dasharray="89.3 350.5" stroke-dashoffset="-266.1" stroke-linecap="butt"
            class="donut-seg" data-target="89.3" data-offset="-266.1"/>
          <!-- Services 9.1% → 40.0 -->
          <circle cx="90" cy="90" r="70" fill="none" stroke="#5856D6" stroke-width="22"
            stroke-dasharray="40.0 399.8" stroke-dashoffset="-355.4" stroke-linecap="butt"
            class="donut-seg" data-target="40.0" data-offset="-355.4"/>
          <!-- Electronics 7.9% → 34.7 -->
          <circle cx="90" cy="90" r="70" fill="none" stroke="#34C759" stroke-width="22"
            stroke-dasharray="34.7 405.1" stroke-dashoffset="-395.4" stroke-linecap="butt"
            class="donut-seg" data-target="34.7" data-offset="-395.4"/>
          <!-- Camera 2.4% → 10.6 -->
          <circle cx="90" cy="90" r="70" fill="none" stroke="#5AC8FA" stroke-width="22"
            stroke-dasharray="10.6 429.2" stroke-dashoffset="-430.1" stroke-linecap="butt"
            class="donut-seg" data-target="10.6" data-offset="-430.1"/>
          <!-- Memberships 1.2% → 5.3 -->
          <circle cx="90" cy="90" r="70" fill="none" stroke="#FF2D55" stroke-width="22"
            stroke-dasharray="5.3 434.5" stroke-dashoffset="-440.7" stroke-linecap="butt"
            class="donut-seg" data-target="5.3" data-offset="-440.7"/>
          <!-- Tyres 0.8% → 3.5 -->
          <circle cx="90" cy="90" r="70" fill="none" stroke="#FF6B00" stroke-width="22"
            stroke-dasharray="3.5 436.3" stroke-dashoffset="-446.0" stroke-linecap="butt"
            class="donut-seg" data-target="3.5" data-offset="-446.0"/>
        </svg>
        <div class="donut-center">
          <div class="donut-center-val">£12.4k</div>
          <div class="donut-center-lbl">Total</div>
        </div>
      </div>
      <div class="legend">
        <div class="legend-item">
          <div class="legend-left"><div class="legend-dot" style="background:#007AFF"></div><div class="legend-name">🚲 Bikes</div></div>
